/**
 * 8-way Or gate: 
 * out = in[0] Or in[1] Or ... Or in[7]
 */
CHIP Or8Way {
    IN in[8];
    OUT out;

    PARTS:
    Or(a= in[0], b= in[1], out= sep1);
    Or(a= in[2], b= sep1, out= sep2);
    Or(a= in[3], b= sep2, out= sep3);
    Or(a= in[4], b= sep3, out= sep4);
    Or(a= in[5], b= sep4, out= sep5);
    Or(a= in[6], b= sep5, out= sep6);
    Or(a= in[7], b= sep6, out= out);
}